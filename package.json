{
	"name": "kitbase-sdk",
	"private": true,
	"description": "Kitbase SDK Monorepo - Event tracking SDKs for multiple languages",
	"scripts": {
		"build": "pnpm -r build",
		"test": "pnpm -r test",
		"lint": "oxlint",
		"format": "oxfmt --write",
		"format:check": "oxfmt",
		"clean": "pnpm -r clean",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm build && changeset publish"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"typescript": "^5.3.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@9.0.0"
}