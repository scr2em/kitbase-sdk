{
	"name": "@kitbase/analytics",
	"version": "0.1.8",
	"description": "Kitbase Analytics SDK for TypeScript and JavaScript",
	"keywords": [
		"analytics",
		"events",
		"kitbase",
		"logging",
		"tracking"
	],
	"homepage": "https://github.com/scr2em/kitbase-sdk/tree/main/customEvents/typescript#readme",
	"bugs": {
		"url": "https://github.com/scr2em/kitbase-sdk/issues"
	},
	"license": "MIT",
	"author": "",
	"repository": {
		"type": "git",
		"url": "https://github.com/scr2em/kitbase-sdk.git",
		"directory": "customEvents/typescript"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "oxlint src",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"dexie": "^4.0.10",
		"uuid": "^13.0.0",
		"web-vitals": "^5.1.0"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3",
		"vitest": "^1.2.0"
	},
	"engines": {
		"node": ">=18"
	}
}