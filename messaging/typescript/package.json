{
	"name": "@kitbase/messaging",
	"version": "1.1.0",
	"description": "Kitbase In-App Messaging SDK for TypeScript and JavaScript",
	"keywords": [
		"in-app-messages",
		"kitbase",
		"messaging"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/scr2em/kitbase-sdk.git",
		"directory": "messaging/typescript"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3",
		"vitest": "^1.2.0"
	},
	"engines": {
		"node": ">=18"
	}
}